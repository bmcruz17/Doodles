# ---------------------------------------------------------------------------
# Client-side env vars (safe to expose — bundled into the frontend by Vite).
# Copy this file to `.env` and fill in values from your Supabase project.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Server-side secrets — DO NOT put these in `.env` or the frontend.
# Set them as Supabase Edge Function secrets instead, e.g.:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
#   ANTHROPIC_API_KEY        Anthropic Claude API key (used by ai-chat)
#   STRIPE_SECRET_KEY        Stripe secret key (create-checkout, stripe-webhook)
#   STRIPE_WEBHOOK_SECRET    Stripe webhook signing secret (stripe-webhook)
# ---------------------------------------------------------------------------
